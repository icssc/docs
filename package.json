{
  "name": "docs.icssc.club",
  "version": "0.0.0",
  "description": "The official documentation site for ICSSC projects",
  "scripts": {
    "build": "next build",
    "build:worker": "opennextjs-cloudflare",
    "dev": "next dev",
    "dev:worker": "wrangler dev --port 8771",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "start": "next start",
    "preview:worker": "pnpm run build:worker && pnpm run dev:worker",
    "deploy:worker": "pnpm run build:worker && wrangler deploy",
    "postinstall": "fumadocs-mdx",
    "prepare": "husky"
  },
  "dependencies": {
    "fumadocs-core": "15.0.14",
    "fumadocs-mdx": "11.5.6",
    "fumadocs-twoslash": "3.1.0",
    "fumadocs-ui": "15.0.14",
    "lucide-react": "0.477.0",
    "next": "15.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "19.7.1",
    "@commitlint/config-conventional": "19.7.1",
    "@commitlint/types": "19.5.0",
    "@fumadocs/cli": "0.0.8",
    "@opennextjs/cloudflare": "0.5.7",
    "@types/mdx": "2.0.13",
    "@types/node": "22.13.8",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@typescript-eslint/eslint-plugin": "8.25.0",
    "autoprefixer": "10.4.20",
    "clsx": "2.1.1",
    "cz-conventional-changelog": "3.3.0",
    "devmoji": "2.3.0",
    "husky": "9.1.7",
    "lint-staged": "15.4.3",
    "postcss": "8.5.3",
    "tailwindcss": "4.0.9",
    "typescript": "5.8.2",
    "wrangler": "3.111.0"
  },
  "packageManager": "pnpm@10.5.2"
}
